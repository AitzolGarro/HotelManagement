{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=HotelReservationDB_Dev;Trusted_Connection=true;MultipleActiveResultSets=true",
    "SqliteConnection": "Data Source=hotel_reservation_demo.db",
    "Redis": "localhost:6379"
  },
  "UseSqlite": true,
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Information",
        "System": "Warning"
      }
    }
  },
  "BookingCom": {
    "BaseUrl": "https://secure-supply-xml.booking.com/test/",
    "Username": "test_user",
    "Password": "test_password",
    "TimeoutSeconds": 30,
    "MaxRetryAttempts": 3,
    "RetryDelaySeconds": 2
  },
  "JwtSettings": {
    "Secret": "HotelReservationSystemSecretKeyForJWTTokenGeneration2024!",
    "Issuer": "HotelReservationSystem",
    "Audience": "HotelReservationSystemUsers",
