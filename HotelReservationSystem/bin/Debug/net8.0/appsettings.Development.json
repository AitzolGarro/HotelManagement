  },
  "CacheSettings": {
    "DefaultExpirationMinutes": 60,
    "ShortExpirationMinutes": 5,
    "MediumExpirationMinutes": 30,
    "LongExpirationHours": 2,
    "StaticDataExpirationHours": 24,
    "EnableDistributedCache": false,
    "EnableMemoryCache": true,
    "MaxMemoryCacheSizeMB": 50
  }
