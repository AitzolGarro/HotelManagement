{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=HotelReservationDemoDB;Trusted_Connection=true;MultipleActiveResultSets=true;AttachDbFilename=|DataDirectory|\\HotelDemo.mdf",
    "SqliteConnection": "Data Source=./hotel_reservation_demo.db",
    "Redis": "localhost:6379"
  },
  "UseSqlite": true,
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "Secret": "HotelReservationSystemSecretKeyForJWTTokenGeneration2024!",
