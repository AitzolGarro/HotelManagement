@{
    var currentPage = ViewContext.RouteData.Values["action"]?.ToString()?.ToLower() ?? "";
    var htmlLang = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
}<!DOCTYPE html>
<html lang="@htmlLang">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Guest Portal</title>

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">
    <!-- Guest Portal CSS -->
    <link rel="stylesheet" href="~/css/guest-portal.css" asp-append-version="true" />

    <style>
        :root {
            --gp-primary: #0d6efd;
            --gp-accent: #198754;
            --gp-bg: #f8f9fa;
            --gp-card-shadow: 0 2px 12px rgba(0,0,0,.08);
        }
        body { background: var(--gp-bg); font-family: 'Segoe UI', system-ui, sans-serif; }
        .gp-navbar { background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%); }
        .gp-navbar .navbar-brand { font-weight: 700; letter-spacing: -.3px; }
        .gp-sidebar { min-height: calc(100vh - 56px); background: #fff; border-right: 1px solid #e9ecef; }
        .gp-sidebar .nav-link { color: #495057; border-radius: 8px; margin: 2px 8px; padding: 10px 14px; transition: all .2s; }
        .gp-sidebar .nav-link:hover, .gp-sidebar .nav-link.active { background: #e7f1ff; color: var(--gp-primary); }
        .gp-sidebar .nav-link i { width: 20px; }
        .gp-main { padding: 24px; }
        .gp-card { background: #fff; border-radius: 12px; box-shadow: var(--gp-card-shadow); border: none; }
        .gp-card .card-header { background: transparent; border-bottom: 1px solid #f0f0f0; font-weight: 600; }
        .status-badge { font-size: .75rem; padding: 4px 10px; border-radius: 20px; font-weight: 600; }
        .status-confirmed { background: #d1e7dd; color: #0f5132; }
        .status-pending { background: #fff3cd; color: #664d03; }
        .status-cancelled { background: #f8d7da; color: #842029; }
        .status-checkedin { background: #cff4fc; color: #055160; }
        .status-checkedout { background: #e2e3e5; color: #41464b; }
        .loyalty-badge { background: linear-gradient(135deg, #ffd700, #ffb300); color: #333; border-radius: 20px; padding: 4px 12px; font-size: .75rem; font-weight: 700; }
        .loyalty-badge.silver { background: linear-gradient(135deg, #c0c0c0, #a8a8a8); color: #fff; }
        .loyalty-badge.gold { background: linear-gradient(135deg, #ffd700, #ffb300); color: #333; }
        .loyalty-badge.platinum { background: linear-gradient(135deg, #e5e4e2, #b0b0b0); color: #333; }
        .loyalty-badge.vip { background: linear-gradient(135deg, #6f42c1, #5a32a3); color: #fff; }
        .gp-mobile-nav { display: none; position: fixed; bottom: 0; left: 0; right: 0; background: #fff; border-top: 1px solid #e9ecef; z-index: 1000; padding: 8px 0; }
        @@media (max-width: 767.98px) {
            .gp-sidebar { display: none; }
            .gp-mobile-nav { display: flex; }
            .gp-main { padding: 16px; padding-bottom: 80px; }
        }
        .gp-mobile-nav a { flex: 1; text-align: center; color: #6c757d; text-decoration: none; font-size: .7rem; }
        .gp-mobile-nav a.active, .gp-mobile-nav a:hover { color: var(--gp-primary); }
        .gp-mobile-nav i { display: block; font-size: 1.3rem; margin-bottom: 2px; }
        #guestAuthRequired { display: none; }
    </style>
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-md navbar-dark gp-navbar" aria-label="Guest Portal Navigation">
        <div class="container-fluid">
            <a class="navbar-brand" href="/GuestPortal/Dashboard">
                <i class="bi bi-building me-2" aria-hidden="true"></i>@L["GP_GuestPortal"]
            </a>
            <div class="d-flex align-items-center gap-2">
                <span class="text-white-50 d-none d-md-inline" id="gpGuestName"></span>

                <!-- Language selector -->
                <div class="dropdown">
                    <button class="btn btn-outline-light btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="@L["Lang_SelectLanguage"]">
                        <i class="bi bi-translate" aria-hidden="true"></i>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li>
                            <form method="post" action="/SetLanguage">
                                <input type="hidden" name="culture" value="en" />
                                <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                                <button type="submit" class="dropdown-item @(System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "en" ? "active" : "")">
                                    🇬🇧 @L["Lang_English"]
                                </button>
                            </form>
                        </li>
                        <li>
                            <form method="post" action="/SetLanguage">
                                <input type="hidden" name="culture" value="es" />
                                <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                                <button type="submit" class="dropdown-item @(System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "es" ? "active" : "")">
                                    🇪🇸 @L["Lang_Spanish"]
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>

                <a href="/GuestPortal/Logout" class="btn btn-outline-light btn-sm" id="gpLogoutBtn" style="display:none!important">
                    <i class="bi bi-box-arrow-right me-1"></i>@L["GP_SignOut"]
                </a>
                <a href="/GuestPortal/Login" class="btn btn-light btn-sm" id="gpLoginBtn">
                    <i class="bi bi-box-arrow-in-right me-1"></i>@L["GP_SignIn"]
                </a>
            </div>
        </div>
    </nav>

    <!-- Auth required banner (shown when not logged in on protected pages) -->
    <div id="guestAuthRequired" class="alert alert-warning m-3 rounded-3" role="alert">
        <i class="bi bi-lock me-2"></i>
        @L["GP_AuthRequired"] <a href="/GuestPortal/Login" class="alert-link">@L["GP_SignIn"]</a>
    </div>

    <div class="container-fluid p-0">
        <div class="row g-0">
            <!-- Sidebar (desktop) -->
            <div class="col-md-2 col-lg-2 gp-sidebar d-none d-md-block">
                <nav class="nav flex-column pt-3" aria-label="Guest Portal Menu">
                    <a class="nav-link @(currentPage == "dashboard" ? "active" : "")"
                       href="/GuestPortal/Dashboard"
                       data-gp-page="dashboard"
                       aria-current="@(currentPage == "dashboard" ? "page" : null)">
                        <i class="bi bi-speedometer2 me-2"></i>@L["GP_Dashboard"]
                    </a>
                    <a class="nav-link @(currentPage == "reservations" ? "active" : "")"
                       href="/GuestPortal/Reservations"
                       data-gp-page="reservations"
                       aria-current="@(currentPage == "reservations" ? "page" : null)">
                        <i class="bi bi-journal-bookmark me-2"></i>@L["GP_MyReservations"]
                    </a>
                    <a class="nav-link @(currentPage == "profile" ? "active" : "")"
                       href="/GuestPortal/Profile"
                       data-gp-page="profile"
                       aria-current="@(currentPage == "profile" ? "page" : null)">
                        <i class="bi bi-person-circle me-2"></i>@L["GP_MyProfile"]
                    </a>
                    <hr class="mx-3">
                    <a class="nav-link text-danger" href="/GuestPortal/Logout" id="gpSidebarLogout">
                        <i class="bi bi-box-arrow-right me-2"></i>@L["GP_SignOut"]
                    </a>
                </nav>
            </div>

            <!-- Main content -->
            <div class="col-md-10 col-lg-10 gp-main">
                <!-- Alert containers -->
                <div id="gpErrorAlert" class="alert alert-danger alert-dismissible fade d-none" role="alert" aria-live="assertive" aria-atomic="true">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    <span id="gpErrorMessage"></span>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close alert"></button>
                </div>
                <div id="gpSuccessAlert" class="alert alert-success alert-dismissible fade d-none" role="alert" aria-live="polite" aria-atomic="true">
                    <i class="bi bi-check-circle-fill me-2"></i>
                    <span id="gpSuccessMessage"></span>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close alert"></button>
                </div>

                @RenderBody()
            </div>
        </div>
    </div>

    <!-- Mobile bottom nav -->
    <nav class="gp-mobile-nav" aria-label="Mobile Guest Portal Navigation">
        <a href="/GuestPortal/Dashboard" data-gp-page="dashboard"
           aria-current="@(currentPage == "dashboard" ? "page" : null)">
            <i class="bi bi-speedometer2"></i>@L["GP_Home"]
        </a>
        <a href="/GuestPortal/Reservations" data-gp-page="reservations"
           aria-current="@(currentPage == "reservations" ? "page" : null)">
            <i class="bi bi-journal-bookmark"></i>@L["GP_Bookings"]
        </a>
        <a href="/GuestPortal/Profile" data-gp-page="profile"
           aria-current="@(currentPage == "profile" ? "page" : null)">
            <i class="bi bi-person-circle"></i>@L["GP_Profile"]
        </a>
    </nav>

    <!-- Bootstrap 5 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Guest Portal JS -->
    <script src="~/js/guest-portal.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
