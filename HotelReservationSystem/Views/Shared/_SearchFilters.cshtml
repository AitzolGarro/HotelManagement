@* 
    Reusable advanced search filters partial view for reservations.
    Usage: @await Html.PartialAsync("_SearchFilters")
    The host page must provide: #hotelFilterRes select, and call AdvancedSearch.init() from its script section.
*@

<!-- Advanced Search Filters -->
<div class="card mb-3" id="searchFiltersCard">
    <!-- Basic filter bar (always visible) -->
    <div class="card-body pb-2">
        <div class="row g-2 align-items-end">
            <div class="col-12 col-sm-6 col-md-3 col-lg-2">
                <label for="dateFromFilter" class="form-label small fw-semibold mb-1">Check-in From</label>
                <input type="date" class="form-control form-control-sm" id="dateFromFilter" aria-label="Check-in from date">
            </div>
            <div class="col-12 col-sm-6 col-md-3 col-lg-2">
                <label for="dateToFilter" class="form-label small fw-semibold mb-1">Check-out To</label>
                <input type="date" class="form-control form-control-sm" id="dateToFilter" aria-label="Check-out to date">
            </div>
            <div class="col-12 col-sm-6 col-md-3 col-lg-2">
                <label for="hotelFilterRes" class="form-label small fw-semibold mb-1">Hotel</label>
                <select class="form-select form-select-sm" id="hotelFilterRes" aria-label="Filter by hotel">
                    <option value="">All Hotels</option>
                </select>
            </div>
            <div class="col-12 col-sm-6 col-md-3 col-lg-2">
                <label for="guestNameFilter" class="form-label small fw-semibold mb-1">Guest Name</label>
                <input type="text" class="form-control form-control-sm" id="guestNameFilter"
                       placeholder="Search guest..." aria-label="Filter by guest name">
            </div>
            <div class="col-12 col-sm-6 col-md-3 col-lg-2">
                <label for="bookingRefFilter" class="form-label small fw-semibold mb-1">Booking Ref</label>
                <input type="text" class="form-control form-control-sm" id="bookingRefFilter"
                       placeholder="e.g. MAN2026..." aria-label="Filter by booking reference">
            </div>
            <div class="col-12 col-sm-6 col-md-3 col-lg-2">
                <div class="d-flex gap-1 flex-wrap">
                    <button type="button" class="btn btn-primary btn-sm flex-grow-1" id="applyReservationFilters"
                            aria-label="Apply filters">
                        <i class="bi bi-funnel-fill me-1"></i>Search
                    </button>
                    <button type="button" class="btn btn-outline-secondary btn-sm" id="clearReservationFilters"
                            title="Clear all filters" aria-label="Clear filters">
                        <i class="bi bi-x-lg"></i>
                    </button>
                    <button type="button" class="btn btn-outline-primary btn-sm" id="toggleAdvancedFilters"
                            data-bs-toggle="collapse" data-bs-target="#advancedFiltersPanel"
                            aria-expanded="false" aria-controls="advancedFiltersPanel"
                            title="Advanced filters">
                        <i class="bi bi-sliders"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Collapsible advanced filters -->
    <div class="collapse" id="advancedFiltersPanel">
        <div class="card-body border-top pt-3 pb-2">
            <div class="row g-2 align-items-end">
                <!-- Status multi-select -->
                <div class="col-12 col-sm-6 col-md-4 col-lg-2">
                    <label class="form-label small fw-semibold mb-1">Status</label>
                    <div class="dropdown" id="statusDropdown">
                        <button class="btn btn-outline-secondary btn-sm w-100 text-start d-flex justify-content-between align-items-center"
                                type="button" data-bs-toggle="dropdown" aria-expanded="false"
                                id="statusDropdownBtn" aria-label="Select statuses">
                            <span id="statusDropdownLabel">All Statuses</span>
                            <i class="bi bi-chevron-down ms-1"></i>
                        </button>
                        <ul class="dropdown-menu p-2" style="min-width:180px;" aria-labelledby="statusDropdownBtn">
                            <li>
                                <div class="form-check">
                                    <input class="form-check-input status-check" type="checkbox" value="1" id="statusPending">
                                    <label class="form-check-label small" for="statusPending">Pending</label>
                                </div>
                            </li>
                            <li>
                                <div class="form-check">
                                    <input class="form-check-input status-check" type="checkbox" value="2" id="statusConfirmed">
                                    <label class="form-check-label small" for="statusConfirmed">Confirmed</label>
                                </div>
                            </li>
                            <li>
                                <div class="form-check">
                                    <input class="form-check-input status-check" type="checkbox" value="4" id="statusCheckedIn">
                                    <label class="form-check-label small" for="statusCheckedIn">Checked In</label>
                                </div>
                            </li>
                            <li>
                                <div class="form-check">
                                    <input class="form-check-input status-check" type="checkbox" value="5" id="statusCheckedOut">
                                    <label class="form-check-label small" for="statusCheckedOut">Checked Out</label>
                                </div>
                            </li>
                            <li>
                                <div class="form-check">
                                    <input class="form-check-input status-check" type="checkbox" value="3" id="statusCancelled">
                                    <label class="form-check-label small" for="statusCancelled">Cancelled</label>
                                </div>
                            </li>
                            <li>
                                <div class="form-check">
                                    <input class="form-check-input status-check" type="checkbox" value="6" id="statusNoShow">
                                    <label class="form-check-label small" for="statusNoShow">No Show</label>
                                </div>
                            </li>
                        </ul>
                    </div>
                </div>

                <!-- Source multi-select -->
                <div class="col-12 col-sm-6 col-md-4 col-lg-2">
                    <label class="form-label small fw-semibold mb-1">Source</label>
                    <div class="dropdown" id="sourceDropdown">
                        <button class="btn btn-outline-secondary btn-sm w-100 text-start d-flex justify-content-between align-items-center"
                                type="button" data-bs-toggle="dropdown" aria-expanded="false"
                                id="sourceDropdownBtn" aria-label="Select sources">
                            <span id="sourceDropdownLabel">All Sources</span>
                            <i class="bi bi-chevron-down ms-1"></i>
                        </button>
                        <ul class="dropdown-menu p-2" style="min-width:180px;" aria-labelledby="sourceDropdownBtn">
                            <li>
                                <div class="form-check">
                                    <input class="form-check-input source-check" type="checkbox" value="1" id="sourceManual">
                                    <label class="form-check-label small" for="sourceManual">Manual</label>
                                </div>
                            </li>
                            <li>
                                <div class="form-check">
                                    <input class="form-check-input source-check" type="checkbox" value="2" id="sourceBookingCom">
                                    <label class="form-check-label small" for="sourceBookingCom">Booking.com</label>
                                </div>
                            </li>
                            <li>
                                <div class="form-check">
                                    <input class="form-check-input source-check" type="checkbox" value="3" id="sourceDirect">
                                    <label class="form-check-label small" for="sourceDirect">Direct</label>
                                </div>
                            </li>
                            <li>
                                <div class="form-check">
                                    <input class="form-check-input source-check" type="checkbox" value="6" id="sourcePhone">
                                    <label class="form-check-label small" for="sourcePhone">Phone</label>
                                </div>
                            </li>
                            <li>
                                <div class="form-check">
                                    <input class="form-check-input source-check" type="checkbox" value="7" id="sourceWalkIn">
                                    <label class="form-check-label small" for="sourceWalkIn">Walk-in</label>
                                </div>
                            </li>
                            <li>
                                <div class="form-check">
                                    <input class="form-check-input source-check" type="checkbox" value="9" id="sourceWebsite">
                                    <label class="form-check-label small" for="sourceWebsite">Website</label>
                                </div>
                            </li>
                        </ul>
                    </div>
                </div>

                <!-- Room type -->
                <div class="col-12 col-sm-6 col-md-4 col-lg-2">
                    <label for="roomTypeFilter" class="form-label small fw-semibold mb-1">Room Type</label>
                    <select class="form-select form-select-sm" id="roomTypeFilter" aria-label="Filter by room type">
                        <option value="">Any Type</option>
                        <option value="1">Single</option>
                        <option value="2">Double</option>
                        <option value="3">Suite</option>
                        <option value="4">Family</option>
                        <option value="5">Deluxe</option>
                        <option value="6">Twin</option>
                        <option value="7">Triple</option>
                        <option value="8">Quad</option>
                        <option value="9">Standard</option>
                    </select>
                </div>

                <!-- Amount range -->
                <div class="col-12 col-sm-6 col-md-4 col-lg-2">
                    <label class="form-label small fw-semibold mb-1">Min Amount (€)</label>
                    <input type="number" class="form-control form-control-sm" id="minAmountFilter"
                           min="0" step="0.01" placeholder="0.00" aria-label="Minimum amount">
                </div>
                <div class="col-12 col-sm-6 col-md-4 col-lg-2">
                    <label class="form-label small fw-semibold mb-1">Max Amount (€)</label>
                    <input type="number" class="form-control form-control-sm" id="maxAmountFilter"
                           min="0" step="0.01" placeholder="No limit" aria-label="Maximum amount">
                </div>

                <!-- Sort -->
                <div class="col-12 col-sm-6 col-md-4 col-lg-2">
                    <label for="sortByFilter" class="form-label small fw-semibold mb-1">Sort By</label>
                    <div class="input-group input-group-sm">
                        <select class="form-select form-select-sm" id="sortByFilter" aria-label="Sort by field">
                            <option value="created">Created</option>
                            <option value="checkin">Check-in</option>
                            <option value="checkout">Check-out</option>
                            <option value="amount">Amount</option>
                            <option value="status">Status</option>
                            <option value="guest">Guest</option>
                        </select>
                        <button class="btn btn-outline-secondary" type="button" id="sortDirBtn"
                                data-dir="desc" title="Toggle sort direction" aria-label="Toggle sort direction">
                            <i class="bi bi-sort-down" id="sortDirIcon"></i>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Saved searches row -->
            <div class="row mt-2">
                <div class="col-12">
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        <small class="text-muted fw-semibold">Saved searches:</small>
                        <div id="savedSearchesList" class="d-flex gap-1 flex-wrap">
                            <small class="text-muted fst-italic" id="noSavedSearches">None saved</small>
                        </div>
                        <button type="button" class="btn btn-outline-success btn-sm ms-auto" id="saveCurrentSearch"
                                title="Save current search" aria-label="Save current search">
                            <i class="bi bi-bookmark-plus me-1"></i>Save Search
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
