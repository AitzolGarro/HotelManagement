<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hotel Reservation System</title>
    
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">
    <!-- Font Awesome Icons -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <!-- FullCalendar CSS -->
    <link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/main.min.css" rel="stylesheet">
    <!-- Date Range Picker CSS -->
    <link href="https://cdn.jsdelivr.net/npm/daterangepicker@3.1.0/daterangepicker.css" rel="stylesheet">
    
    <!-- GridStack CSS -->
    <link href="https://cdn.jsdelivr.net/npm/gridstack@7.2.1/dist/gridstack.min.css" rel="stylesheet"/>
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    
    <!-- PWA Manifest -->
    <link rel="manifest" href="~/manifest.json" />
    <meta name="theme-color" content="#0d6efd" />
</head>
<body>
    <!-- Skip to content link for accessibility -->
    <a href="#main-content" class="skip-link">Skip to main content</a>
    
    <header role="banner">
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary" aria-label="Main Navigation">
            <div class="container-fluid">
                <a class="navbar-brand" href="/" aria-label="Home">
                    <i class="bi bi-building" aria-hidden="true"></i>
                    Hotel Reservation System
                </a>
                
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto" role="menubar">
                        <li class="nav-item" role="menuitem">
                            <a class="nav-link" href="/" data-section="dashboard">
                                <i class="bi bi-speedometer2" aria-hidden="true"></i>
                                Dashboard
                            </a>
                        </li>
                        <li class="nav-item" role="menuitem">
                            <a class="nav-link" href="/Home/calendar" data-section="calendar">
                                <i class="bi bi-calendar3" aria-hidden="true"></i>
                                Calendar
                            </a>
                        </li>
                        <li class="nav-item" data-role="manager" role="menuitem">
                            <a class="nav-link" href="/Home/properties" data-section="properties">
                                <i class="bi bi-buildings" aria-hidden="true"></i>
                                Properties
                            </a>
                        </li>
                        <li class="nav-item" role="menuitem">
                            <a class="nav-link" href="/Home/reservations" data-section="reservations">
                                <i class="bi bi-journal-bookmark" aria-hidden="true"></i>
                                Reservations
                            </a>
                        </li>
                        <li class="nav-item" data-role="manager" role="menuitem">
                            <a class="nav-link" href="/Home/reports" data-section="reports">
                                <i class="bi bi-graph-up" aria-hidden="true"></i>
                                Reports
                            </a>
                        </li>
                    </ul>
                    
                    <ul class="navbar-nav">
                        <li class="nav-item dropdown" id="userMenu" style="display: none;">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="User Menu">
                                <i class="bi bi-person-circle me-1" aria-hidden="true"></i>
                                <span id="userName"></span>
                                <small class="text-muted ms-1" id="userRole" data-user-role></small>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end" aria-label="User actions">
                                <li class="dropdown-header">
                                    <div class="d-flex align-items-center">
                                        <i class="bi bi-person-circle fs-4 me-2" aria-hidden="true"></i>
                                        <div>
                                            <div class="fw-semibold" id="userFullName"></div>
                                            <small class="text-muted" id="userEmail"></small>
                                        </div>
                                    </div>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="#" id="profileLink">
                                    <i class="bi bi-person me-2" aria-hidden="true"></i> My Profile
                                </a></li>
                                <li><a class="dropdown-item" href="#" id="changePasswordLink">
                                    <i class="bi bi-key me-2" aria-hidden="true"></i> Change Password
                                </a></li>
                                <li data-role="admin"><a class="dropdown-item" href="#" id="userManagementLink">
                                    <i class="bi bi-people me-2" aria-hidden="true"></i> User Management
                                </a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="#" id="settingsLink">
                                    <i class="bi bi-gear me-2" aria-hidden="true"></i> Settings
                                </a></li>
                                <li><a class="dropdown-item" href="#" id="helpLink">
                                    <i class="bi bi-question-circle me-2" aria-hidden="true"></i> Help & Support
                                </a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" href="#" id="logoutBtn">
                                    <i class="bi bi-box-arrow-right me-2" aria-hidden="true"></i> Sign Out
                                </a></li>
                            </ul>
                        </li>
                        <li class="nav-item" id="loginMenu">
                            <a class="nav-link" href="/Home/login">
                                <i class="bi bi-box-arrow-in-right" aria-hidden="true"></i>
                                Sign In
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main id="main-content" class="container-fluid mt-3" role="main">
        <!-- Loading overlay -->
        <div id="loadingOverlay" class="loading-overlay" style="display: none;">
            <div class="loading-spinner">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <div class="mt-2">Loading...</div>
            </div>
        </div>

        <!-- Error alert -->
        <div id="errorAlert" class="alert alert-danger alert-dismissible fade" role="alert" style="display: none;">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <span id="errorMessage"></span>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>

        <!-- Success alert -->
        <div id="successAlert" class="alert alert-success alert-dismissible fade" role="alert" style="display: none;">
            <i class="bi bi-check-circle-fill"></i>
            <span id="successMessage"></span>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>

        @RenderBody()
    </main>

    <!-- Bottom Navigation for Mobile -->
    <nav class="mobile-bottom-nav d-lg-none">
        <div class="d-flex justify-content-around w-100">
            <a href="/" class="nav-item text-center p-2 text-decoration-none text-dark" data-section="dashboard">
                <i class="bi bi-speedometer2 d-block fs-5"></i>
                <small>Home</small>
            </a>
            <a href="/Home/calendar" class="nav-item text-center p-2 text-decoration-none text-dark" data-section="calendar">
                <i class="bi bi-calendar3 d-block fs-5"></i>
                <small>Calendar</small>
            </a>
            <a href="/Home/reservations" class="nav-item text-center p-2 text-decoration-none text-dark" data-section="reservations">
                <i class="bi bi-journal-bookmark d-block fs-5"></i>
                <small>Bookings</small>
            </a>
        </div>
    </nav>

    <!-- Bootstrap 5 JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <!-- jQuery (required for date range picker) -->
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <!-- Moment.js (required for date range picker) -->
    <script src="https://cdn.jsdelivr.net/npm/moment@2.29.4/moment.min.js"></script>
    <!-- Date Range Picker JS -->
    <script src="https://cdn.jsdelivr.net/npm/daterangepicker@3.1.0/daterangepicker.min.js"></script>
    <!-- FullCalendar JS -->
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.js"></script>
    <!-- SignalR Client -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.14/signalr.min.js"></script>
    <!-- Custom JavaScript modules -->
    <script src="~/js/modules/api.js" asp-append-version="true"></script>
    <script src="~/js/modules/auth.js" asp-append-version="true"></script>
    <script src="~/js/modules/ui.js" asp-append-version="true"></script>
    <script src="~/js/modules/signalr.js" asp-append-version="true"></script>
    <script src="~/js/modules/notifications.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/sw.js').then(registration => {
                    console.log('SW registered: ', registration);
                }).catch(registrationError => {
                    console.log('SW registration failed: ', registrationError);
                });
            });
        }
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>