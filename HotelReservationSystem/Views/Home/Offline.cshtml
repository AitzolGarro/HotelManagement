@{
    ViewData["Title"] = L["Offline_Title"].Value;
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-sm-10 col-md-8 col-lg-6 text-center">

            <!-- Offline illustration -->
            <div class="mb-4" aria-hidden="true">
                <i class="bi bi-wifi-off" style="font-size: 5rem; color: #6c757d;"></i>
            </div>

            <h1 class="h2 fw-bold mb-2">@L["Offline_Heading"]</h1>
            <p class="text-muted mb-4">
                @L["Offline_Message"]
            </p>

            <!-- Retry button -->
            <button id="retryBtn" class="btn btn-primary btn-lg mb-3"
                    onclick="window.location.reload()" aria-label="@L["Offline_TryReconnect"]">
                <i class="bi bi-arrow-clockwise me-2" aria-hidden="true"></i>@L["Offline_TryAgain"]
            </button>

            <p class="text-muted small mb-4">
                Or <a href="/" class="text-decoration-none">@L["Offline_GoHome"]</a>
            </p>

            <!-- What's available offline -->
            <div class="card border-0 bg-light rounded-3 text-start">
                <div class="card-body p-4">
                    <h2 class="h6 fw-bold mb-3">
                        <i class="bi bi-check-circle-fill text-success me-2" aria-hidden="true"></i>
                        @L["Offline_AvailableOffline"]
                    </h2>
                    <ul class="list-unstyled mb-0 small text-muted">
                        <li class="mb-2">
                            <i class="bi bi-calendar3 me-2 text-primary" aria-hidden="true"></i>
                            @L["Offline_CalendarData"]
                        </li>
                        <li class="mb-2">
                            <i class="bi bi-journal-bookmark me-2 text-primary" aria-hidden="true"></i>
                            @L["Offline_CachedReservations"]
                        </li>
                        <li class="mb-0">
                            <i class="bi bi-person me-2 text-primary" aria-hidden="true"></i>
                            @L["Offline_GuestInfoReadonly"]
                        </li>
                    </ul>
                </div>
            </div>

            <!-- Connection status indicator -->
            <div id="connectionStatus" class="mt-4 small text-muted" role="status" aria-live="polite">
                <span id="statusText">
                    <i class="bi bi-circle-fill text-danger me-1" style="font-size:0.5rem;" aria-hidden="true"></i>
                    @L["Offline_StatusOffline"]
                </span>
            </div>

        </div>
    </div>
</div>

@section Scripts {
<script>
    // Auto-retry when connection is restored
    window.addEventListener('online', function () {
        document.getElementById('statusText').innerHTML =
            '<i class="bi bi-circle-fill text-success me-1" style="font-size:0.5rem;" aria-hidden="true"></i>' +
            '@Html.Raw(L["Offline_BackOnlineRedirecting"].Value)';
        setTimeout(() => {
            const intended = sessionStorage.getItem('offline_intended_url') || '/';
            window.location.href = intended;
        }, 800);
    });

    window.addEventListener('offline', function () {
        document.getElementById('statusText').innerHTML =
            '<i class="bi bi-circle-fill text-danger me-1" style="font-size:0.5rem;" aria-hidden="true"></i>' +
            '@Html.Raw(L["Offline_StatusOffline"].Value)';
    });

    // Store the page the user was trying to reach
    const ref = document.referrer;
    if (ref && !ref.includes('/offline')) {
        sessionStorage.setItem('offline_intended_url', ref);
    }

    // Pulse the retry button every 30s automatically
    setInterval(() => {
        if (navigator.onLine) window.location.reload();
    }, 30000);
</script>
}
