@{
    ViewData["Title"] = "Dashboard";
}

<div id="dashboardContainer">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="h3 mb-0">
                    <i class="bi bi-speedometer2"></i>
                    Dashboard
                </h1>
                <div class="d-flex gap-2">
                    <select class="form-select form-select-sm" id="hotelFilter" style="width: auto;">
                        <option value="">All Hotels</option>
                        <!-- Hotel options will be populated by JavaScript -->
                    </select>
                    <button class="btn btn-outline-primary btn-sm" id="refreshDashboard">
                        <i class="bi bi-arrow-clockwise"></i>
                        Refresh
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Error Container -->
    <div id="dashboardError" style="display: none;"></div>

    <!-- KPI Cards Row -->
    <div class="row mb-4 dashboard-content">
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card dashboard-card h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <div class="dashboard-stat" id="occupancyRate">--</div>
                            <div class="dashboard-label">Occupancy Rate</div>
                            <div class="dashboard-subtitle small text-muted" id="occupancySubtitle">--</div>
                            <div class="dashboard-trend" id="occupancyTrend"></div>
                        </div>
                        <div class="align-self-center">
                            <i class="bi bi-graph-up fs-1 text-primary"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card dashboard-card h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <div class="dashboard-stat" id="monthlyRevenue">--</div>
                            <div class="dashboard-label">Monthly Revenue</div>
                            <div class="dashboard-subtitle small text-muted" id="monthlyRevenueSubtitle">--</div>
                            <div class="dashboard-trend" id="monthlyRevenueTrend"></div>
                        </div>
                        <div class="align-self-center">
                            <i class="bi bi-currency-dollar fs-1 text-success"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card dashboard-card h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <div class="dashboard-stat" id="todayRevenue">--</div>
                            <div class="dashboard-label">Today's Revenue</div>
                            <div class="dashboard-subtitle small text-muted" id="todayRevenueSubtitle">--</div>
                            <div class="dashboard-trend" id="todayRevenueTrend"></div>
                        </div>
                        <div class="align-self-center">
                            <i class="bi bi-cash-coin fs-1 text-info"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card dashboard-card h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <div class="dashboard-stat" id="projectedRevenue">--</div>
                            <div class="dashboard-label">Projected Revenue</div>
                            <div class="dashboard-subtitle small text-muted" id="projectedRevenueSubtitle">--</div>
                            <div class="dashboard-trend" id="projectedRevenueTrend"></div>
                        </div>
                        <div class="align-self-center">
                            <i class="bi bi-graph-up-arrow fs-1 text-warning"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Occupancy Breakdown -->
    <div class="row mb-4 dashboard-content">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="bi bi-pie-chart"></i>
                        Occupancy Breakdown
                    </h5>
                </div>
                <div class="card-body">
                    <div id="occupancyBreakdown">
                        <div class="text-center text-muted py-3">
                            <i class="bi bi-hourglass-split"></i>
                            Loading occupancy data...
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content Row -->
    <div class="row dashboard-content">
        <!-- Today's Activity -->
        <div class="col-lg-8 mb-4">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="bi bi-calendar-day"></i>
                        Today's Activity
                    </h5>
                    <small class="text-muted" id="todayDate"></small>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h6 class="border-start border-success border-3 ps-3 mb-0">Check-ins</h6>
                                <span class="badge bg-success" id="checkInCount">0</span>
                            </div>
                            <div id="todayCheckIns" class="mb-4">
                                <div class="text-center text-muted py-3">
                                    <i class="bi bi-clock-history fs-1"></i>
                                    <p class="mt-2">Loading check-ins...</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h6 class="border-start border-warning border-3 ps-3 mb-0">Check-outs</h6>
                                <span class="badge bg-warning" id="checkOutCount">0</span>
                            </div>
                            <div id="todayCheckOuts">
                                <div class="text-center text-muted py-3">
                                    <i class="bi bi-clock-history fs-1"></i>
                                    <p class="mt-2">Loading check-outs...</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Notifications & Alerts -->
        <div class="col-lg-4 mb-4">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="bi bi-bell"></i>
                        Notifications
                        <span class="badge bg-danger ms-2" id="notificationBadge" style="display: none;">0</span>
                    </h5>
                </div>
                <div class="card-body">
                    <!-- Notification Summary -->
                    <div class="row text-center mb-3">
                        <div class="col-4">
                            <div class="notification-summary">
                                <div class="fw-bold text-danger" id="criticalNotificationCount">0</div>
                                <div class="small text-muted">Critical</div>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="notification-summary">
                                <div class="fw-bold text-warning" id="warningNotificationCount">0</div>
                                <div class="small text-muted">Warning</div>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="notification-summary">
                                <div class="fw-bold text-info" id="infoNotificationCount">0</div>
                                <div class="small text-muted">Info</div>
                            </div>
                        </div>
                    </div>
                    
                    <div id="notificationsList">
                        <div class="text-center text-muted py-3">
                            <i class="bi bi-bell-slash fs-1"></i>
                            <p class="mt-2">Loading notifications...</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Revenue Chart -->
    <div class="row mb-4 dashboard-content">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="bi bi-graph-up"></i>
                        Revenue Trend (Last 30 Days)
                    </h5>
                </div>
                <div class="card-body">
                    <div style="height: 300px; position: relative;">
                        <canvas id="revenueChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Reservations -->
    <div class="row dashboard-content">
        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="bi bi-clock-history"></i>
                        Recent Reservations
                    </h5>
                    <a href="/reservations" class="btn btn-outline-primary btn-sm">
                        View All
                    </a>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover" id="recentReservationsTable">
                            <thead>
                                <tr>
                                    <th>Booking Ref</th>
                                    <th>Guest</th>
                                    <th>Hotel</th>
                                    <th>Room</th>
                                    <th>Check-in</th>
                                    <th>Check-out</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td colspan="8" class="text-center text-muted py-4">
                                        <i class="bi bi-hourglass-split fs-1"></i>
                                        <p class="mt-2">Loading recent reservations...</p>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div> <!-- End dashboardContainer -->

@section Scripts {
    <!-- Chart.js for revenue charts -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    
    <!-- Dashboard module -->
    <script src="~/js/modules/dashboard.js"></script>
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Set today's date
            const todayDateElement = document.getElementById('todayDate');
            if (todayDateElement) {
                todayDateElement.textContent = new Date().toLocaleDateString('en-US', {
                    weekday: 'long',
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric'
                });
            }
            
            // Load hotel options for filter
            loadHotelOptions();
        });
        
        async function loadHotelOptions() {
            try {
                const apiClient = new ApiClient();
                const hotels = await apiClient.get('/api/hotels');
                const hotelFilter = document.getElementById('hotelFilter');
                
                if (hotelFilter && hotels) {
                    // Clear existing options except "All Hotels"
                    hotelFilter.innerHTML = '<option value="">All Hotels</option>';
                    
                    // Add hotel options
                    hotels.forEach(hotel => {
                        const option = document.createElement('option');
                        option.value = hotel.id;
                        option.textContent = hotel.name;
                        hotelFilter.appendChild(option);
                    });
                }
            } catch (error) {
                console.error('Error loading hotel options:', error);
            }
        }
    </script>
}