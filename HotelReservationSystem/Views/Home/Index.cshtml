@{
    ViewData["Title"] = L["Dashboard_Title"].Value;
}

<div id="dashboardContainer">

    <div id="dashboard-status" class="visually-hidden" aria-live="polite" aria-atomic="true"></div>

    <!-- ── Toolbar ──────────────────────────────────────────────────────── -->
    <div class="row mb-3 g-2 align-items-center">
        <div class="col-12 col-md-auto">
            <h1 class="h4 mb-0">
                <i class="bi bi-speedometer2 me-1" aria-hidden="true"></i>@L["Dashboard_Title"]
            </h1>
        </div>

        <!-- Date range -->
        <div class="col-12 col-sm-6 col-md-auto">
            <input type="text" id="dashboardDateRange"
                   class="form-control form-control-sm"
                   placeholder="@L["Dashboard_DateRange"]"
                   aria-label="Date range filter"
                   style="min-width:200px;" />
        </div>

        <!-- Hotel filter -->
        <div class="col-12 col-sm-6 col-md-auto">
            <select class="form-select form-select-sm" id="hotelFilter"
                    aria-label="Hotel filter" style="min-width:140px;">
                <option value="">@L["Dashboard_AllHotels"]</option>
            </select>
        </div>

        <!-- Auto-refresh -->
        <div class="col-12 col-sm-auto d-flex align-items-center gap-2">
            <div class="form-check form-switch mb-0">
                <input class="form-check-input" type="checkbox" id="autoRefreshToggle"
                       role="switch" aria-label="Auto-refresh toggle" />
                <label class="form-check-label small" for="autoRefreshToggle">@L["Dashboard_AutoRefresh"]</label>
            </div>
            <select class="form-select form-select-sm" id="refreshInterval"
                    style="width:auto;" aria-label="Refresh interval">
                <option value="60">1 min</option>
                <option value="300" selected>5 min</option>
                <option value="600">10 min</option>
                <option value="1800">30 min</option>
            </select>
        </div>

        <!-- Action buttons -->
        <div class="col-12 col-sm-auto ms-md-auto d-flex flex-wrap gap-2">
            <button class="btn btn-outline-primary btn-sm" id="refreshDashboard"
                    title="Refresh data" aria-label="Refresh dashboard">
                <i class="bi bi-arrow-clockwise" aria-hidden="true"></i>
                <span class="d-none d-sm-inline">@L["Common_Refresh"]</span>
            </button>
            <button class="btn btn-outline-secondary btn-sm" id="addWidgetBtn"
                    title="Add widget" aria-label="Add widget"
                    data-bs-toggle="modal" data-bs-target="#addWidgetModal">
                <i class="bi bi-plus-lg" aria-hidden="true"></i>
                <span class="d-none d-sm-inline">@L["Dashboard_AddWidget"]</span>
            </button>
            <button class="btn btn-outline-success btn-sm" id="saveLayoutBtn"
                    title="Save layout" aria-label="Save layout">
                <i class="bi bi-save" aria-hidden="true"></i>
                <span class="d-none d-sm-inline">@L["Dashboard_SaveLayout"]</span>
            </button>
            <button class="btn btn-outline-danger btn-sm" id="resetLayoutBtn"
                    title="Reset to default" aria-label="Reset layout">
                <i class="bi bi-arrow-counterclockwise" aria-hidden="true"></i>
                <span class="d-none d-sm-inline">@L["Dashboard_ResetLayout"]</span>
            </button>
        </div>
    </div>

    <!-- ── Error banner ──────────────────────────────────────────────────── -->
    <div id="dashboardError" style="display:none;" role="alert" aria-live="assertive"></div>

    <!-- ── GridStack container ───────────────────────────────────────────── -->
    <div class="dashboard-keyboard-hint mb-2" aria-hidden="true">
        <span><kbd class="kbd-hint">Tab</kbd> @L["Dashboard_TabNavigateWidgets"]</span>
        <span><kbd class="kbd-hint">Alt</kbd>+<kbd class="kbd-hint">/</kbd> @L["Dashboard_AllShortcutsHint"]</span>
    </div>
    <div class="grid-stack" id="dashboardGrid" aria-label="Dashboard widgets"
         aria-describedby="dashboardGrid-hint">
        <!-- Widgets are rendered dynamically by dashboard.js -->
    </div>
    <div id="dashboardGrid-hint" class="visually-hidden">@L["Dashboard_GridHint"]</div>

</div><!-- /#dashboardContainer -->

<!-- ── Add Widget Modal ──────────────────────────────────────────────────── -->
<div class="modal fade" id="addWidgetModal" tabindex="-1"
     aria-labelledby="addWidgetModalLabel" aria-modal="true" role="dialog">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addWidgetModalLabel">
                    <i class="bi bi-grid-3x3-gap me-2" aria-hidden="true"></i>@L["Dashboard_AddWidget"]
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"
                        aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted small mb-3">
                    @L["Dashboard_SelectWidget"]
                </p>
                <div id="widgetCatalog" class="row g-3">
                    <div class="col-12 text-center py-4">
                        <div class="spinner-border spinner-border-sm text-primary" role="status">
                            <span class="visually-hidden">@L["Dashboard_LoadingWidgets"]</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary"
                        data-bs-dismiss="modal">@L["Common_Close"]</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <!-- GridStack JS (all-in-one includes drag/resize) -->
    <script src="https://cdn.jsdelivr.net/npm/gridstack@7.2.1/dist/gridstack-all.js"></script>
    <!-- Dashboard customization module -->
    <script src="~/js/modules/dashboard.js" asp-append-version="true"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Date range picker
            $('#dashboardDateRange').daterangepicker({
                startDate : moment().subtract(29, 'days'),
                endDate   : moment(),
                ranges    : {
                    ((window._I18N||{})['Calendar_Today']||'Today')       : [moment(), moment()],
                    ((window._I18N||{})['Calendar_Yesterday']||'Yesterday')   : [moment().subtract(1,'days'), moment().subtract(1,'days')],
                    ((window._I18N||{})['Calendar_Last7Days']||'Last 7 Days') : [moment().subtract(6,'days'), moment()],
                    ((window._I18N||{})['Calendar_Last30Days']||'Last 30 Days'): [moment().subtract(29,'days'), moment()],
                    ((window._I18N||{})['Calendar_ThisMonth']||'This Month')  : [moment().startOf('month'), moment().endOf('month')],
                    ((window._I18N||{})['Calendar_LastMonth']||'Last Month')  : [moment().subtract(1,'month').startOf('month'),
                                     moment().subtract(1,'month').endOf('month')]
                }
            }, function (start, end) {
                if (window.dashboardManager) {
                    window.dashboardManager.setDateRange(start.toDate(), end.toDate());
                }
            });

            // Load hotel options
            loadHotelOptions();
        });

        async function loadHotelOptions() {
            try {
                const api      = new ApiClient();
                const response = await api.get('/hotels');
                const hotels   = (response && response.items) ? response.items : (response || []);
                const sel      = document.getElementById('hotelFilter');
                if (sel && hotels.length) {
                    hotels.forEach(h => {
                        const opt = document.createElement('option');
                        opt.value       = h.id;
                        opt.textContent = h.name;
                        sel.appendChild(opt);
                    });
                }
            } catch (e) {
                console.warn('Could not load hotel options:', e);
            }
        }
    </script>
}
