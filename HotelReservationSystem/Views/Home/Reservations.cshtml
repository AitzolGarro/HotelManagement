        async function editReservation(id) {
            try {
                const reservation = await API.getReservation(id);
                await populateReservationForm(reservation);
                
                // Show modal
                const modal = new bootstrap.Modal(document.getElementById('reservationModal'));
                modal.show();
            } catch (error) {
                console.error('Error loading reservation for editing:', error);
                UI.showError('Failed to load reservation for editing');
            }
        }

        function editReservationFromDetails() {
            // Close details modal
            bootstrap.Modal.getInstance(document.getElementById('reservationDetailsModal')).hide();
            
            // Open edit modal
            setTimeout(() => {
                editReservation(currentReservationId);
            }, 300);
        }

        async function populateReservationForm(reservation) {
            isEditMode = true;
            currentReservationId = reservation.id;
            
            // Update modal title
            document.getElementById('reservationModalLabel').innerHTML = `
                <i class="bi bi-pencil"></i>
                Edit Reservation
            `;
            
            // Populate form fields
            document.getElementById('reservationHotel').value = reservation.hotelId;
            await onHotelSelectionChange(); // Load rooms for the hotel
            
            // Wait a bit for rooms to load, then set the room
            setTimeout(() => {
                document.getElementById('reservationRoom').value = reservation.roomId;
            }, 100);
            
            document.getElementById('checkInDate').value = reservation.checkInDate.split('T')[0];
            document.getElementById('checkOutDate').value = reservation.checkOutDate.split('T')[0];
            document.getElementById('numberOfGuests').value = reservation.numberOfGuests;
            document.getElementById('totalAmount').value = reservation.totalAmount;
            document.getElementById('reservationStatus').value = reservation.status;
            document.getElementById('bookingReference').value = reservation.bookingReference || '';
            document.getElementById('specialRequests').value = reservation.specialRequests || '';
            document.getElementById('internalNotes').value = reservation.internalNotes || '';
            
            // Populate guest information (extract from guestName)
            const nameParts = reservation.guestName.split(' ');
            document.getElementById('guestFirstName').value = nameParts[0] || '';
            document.getElementById('guestLastName').value = nameParts.slice(1).join(' ') || '';
            document.getElementById('guestEmail').value = reservation.guestEmail || '';
            document.getElementById('guestPhone').value = reservation.guestPhone || '';
            
            // Show save button immediately for editing
            document.getElementById('saveReservationBtn').style.display = 'inline-block';
        }

        async function cancelReservation(id) {
            const reason = prompt('Please enter a reason for cancellation:');
            if (!reason) return;
            
            try {
                await API.delete(`/reservations/${id}`, { reason });
                UI.showSuccess('Reservation cancelled successfully!');
                await loadReservationsData();
            } catch (error) {
                console.error('Error cancelling reservation:', error);
                UI.showError('Failed to cancel reservation');
            }
        }

        async function checkInReservation(id) {
            if (!confirm('Are you sure you want to check in this reservation?')) return;
            
            try {
                await API.post(`/reservations/${id}/checkin`);
                UI.showSuccess('Guest checked in successfully!');
                await loadReservationsData();
            } catch (error) {
                console.error('Error checking in reservation:', error);
                UI.showError('Failed to check in reservation');
            }
        }

        async function checkOutReservation(id) {
            if (!confirm('Are you sure you want to check out this reservation?')) return;
            
            try {
                await API.post(`/reservations/${id}/checkout`);
                UI.showSuccess('Guest checked out successfully!');
                await loadReservationsData();
            } catch (error) {
                console.error('Error checking out reservation:', error);
                UI.showError('Failed to check out reservation');
            }
        }

        function resetReservationModal() {
            document.getElementById('reservationForm').reset();
            document.getElementById('reservationRoom').disabled = true;
            document.getElementById('saveReservationBtn').style.display = 'none';
            hideAvailabilityResults();
            
            // Clear validation states
            const inputs = document.querySelectorAll('#reservationForm .is-invalid');
            inputs.forEach(input => UI.clearFieldError(input));
        }

        function resetDateBlockingModal() {
            document.getElementById('dateBlockingForm').reset();
            document.getElementById('blockingRoom').disabled = true;
            
            // Clear validation states
            const inputs = document.querySelectorAll('#dateBlockingForm .is-invalid');
            inputs.forEach(input => UI.clearFieldError(input));
        }

        function applyReservationFilters() {
            const filters = {
                dateFrom: document.getElementById('dateFromFilter').value,
                dateTo: document.getElementById('dateToFilter').value,
                hotel: document.getElementById('hotelFilterRes').value,
                status: document.getElementById('statusFilterRes').value,
                source: document.getElementById('sourceFilter').value
            };
            
            loadReservationsData(filters);
        }

        function clearReservationFilters() {
            document.getElementById('dateFromFilter').value = '';
            document.getElementById('dateToFilter').value = '';
            document.getElementById('hotelFilterRes').value = '';
            document.getElementById('statusFilterRes').value = '';
            document.getElementById('sourceFilter').value = '';
            
            loadReservationsData();
        }

        // Utility functions for status and source mapping
        function getStatusDisplayName(status) {
            const statusNames = {
                0: 'Pending',
                1: 'Confirmed', 
                2: 'Checked In',
                3: 'Checked Out',
                4: 'Cancelled'
            };
            return statusNames[status] || 'Unknown';
        }

        function getStatusBadgeClass(status) {
            const statusClasses = {
                0: 'bg-warning',
                1: 'bg-success',
                2: 'bg-primary',
                3: 'bg-info',
                4: 'bg-danger'
            };
            return statusClasses[status] || 'bg-secondary';
        }

        function getSourceDisplayName(source) {
            const sourceNames = {
                0: 'Manual',
                1: 'Booking.com',
                2: 'Direct'
            };
            return sourceNames[source] || 'Unknown';
        }

        function getSourceBadgeClass(source) {
            const sourceClasses = {
                0: 'bg-secondary',
                1: 'bg-primary',
                2: 'bg-success'
            };
            return sourceClasses[source] || 'bg-secondary';
        }

        function getRoomTypeDisplayName(type) {
            const typeNames = {
                0: 'Single',
                1: 'Double',
                2: 'Twin',
                3: 'Suite',
                4: 'Family',
                5: 'Deluxe'
            };
            return typeNames[type] || 'Unknown';
        }

        function mapStatusToEnum(statusString) {
            const statusMap = {
                'pending': 0,
                'confirmed': 1,
                'checkedin': 2,
                'checkedout': 3,
                'cancelled': 4
            };
            return statusMap[statusString];
        }

        function mapSourceToEnum(sourceString) {
            const sourceMap = {
                'manual': 0,
                'booking': 1,
                'direct': 2
            };
            return sourceMap[sourceString];
        }
    </script>
}