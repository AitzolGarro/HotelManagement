@{
    ViewData["Title"] = L["Nav_Properties"].Value;
}

<div class="row">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3 mb-0">
                <i class="bi bi-buildings"></i>
                @L["Properties_Title"]
            </h1>
            <button type="button" class="btn btn-primary" id="addHotelBtn" data-role="admin">
                <i class="bi bi-plus-circle"></i>
                @L["Properties_AddHotel"]
            </button>
        </div>
    </div>
</div>

<!-- Properties List -->
<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="bi bi-building"></i>
                    @L["Properties_Hotels"]
                </h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover" id="hotelsTable">
                        <thead>
                            <tr>
                                <th>@L["Common_Name"]</th>
                                <th>@L["GP_Prof_Address"]</th>
                                <th>@L["Calendar_Phone"]</th>
                                <th>@L["Calendar_Email"]</th>
                                <th>@L["Properties_Hotels"]</th>
                                <th>@L["Calendar_Status"]</th>
                                <th>@L["Common_Actions"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td colspan="7" class="text-center text-muted py-4">
                                    <i class="bi bi-building fs-1"></i>
                                    <p class="mt-2">@L["Properties_LoadingHotels"]</p>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Rooms Section (will show when a hotel is selected) -->
<div class="row mt-4" id="roomsSection" style="display: none;">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="bi bi-door-closed"></i>
                    @L["Properties_Rooms"] - <span id="selectedHotelName"></span>
                </h5>
                <button type="button" class="btn btn-primary btn-sm" id="addRoomBtn" data-role="manager">
                    <i class="bi bi-plus-circle"></i>
                    @L["Properties_AddRoom"]
                </button>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover" id="roomsTable">
                        <thead>
                            <tr>
                                <th>@L["Properties_RoomNumber"]</th>
                                <th>@L["Properties_Type"]</th>
                                <th>@L["Properties_Capacity"]</th>
                                <th>@L["Properties_BaseRate"]</th>
                                <th>@L["Calendar_Status"]</th>
                                <th>@L["Common_Actions"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            <!-- Rooms will be loaded dynamically -->
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Properties module -->
    <script src="~/js/modules/properties.js" asp-append-version="true"></script>
    
    <script>
        let propertiesManager;
        
        document.addEventListener('DOMContentLoaded', async function() {
            console.log('Properties page loaded');
            
            // Initialize properties manager
            propertiesManager = new PropertiesManager();
            await propertiesManager.initialize();
        });
        
        // Legacy function for backward compatibility
        function showHotelRooms(hotelId, hotelName) {
            if (propertiesManager) {
                propertiesManager.showHotelRooms(hotelId, hotelName);
            }
        }
    </script>
}
