@{
    ViewData["Title"] = "Properties";
}

<div class="row">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3 mb-0">
                <i class="bi bi-buildings"></i>
                Properties Management
            </h1>
            <button type="button" class="btn btn-primary" data-role="admin">
                <i class="bi bi-plus-circle"></i>
                Add Hotel
            </button>
        </div>
    </div>
</div>

<!-- Properties List -->
<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="bi bi-building"></i>
                    Hotels
                </h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover" id="hotelsTable">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Address</th>
                                <th>Phone</th>
                                <th>Email</th>
                                <th>Rooms</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td colspan="7" class="text-center text-muted py-4">
                                    <i class="bi bi-building fs-1"></i>
                                    <p class="mt-2">Loading hotels...</p>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Rooms Section (will show when a hotel is selected) -->
<div class="row mt-4" id="roomsSection" style="display: none;">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="bi bi-door-closed"></i>
                    Rooms - <span id="selectedHotelName"></span>
                </h5>
                <button type="button" class="btn btn-primary btn-sm" data-role="manager">
                    <i class="bi bi-plus-circle"></i>
                    Add Room
                </button>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover" id="roomsTable">
                        <thead>
                            <tr>
                                <th>Room Number</th>
                                <th>Type</th>
                                <th>Capacity</th>
                                <th>Base Rate</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <!-- Rooms will be loaded dynamically -->
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Properties module -->
    <script src="~/js/modules/properties.js" asp-append-version="true"></script>
    
    <script>
        let propertiesManager;
        
        document.addEventListener('DOMContentLoaded', async function() {
            console.log('Properties page loaded');
            
            // Initialize properties manager
            propertiesManager = new PropertiesManager();
            await propertiesManager.initialize();
        });
        
        // Legacy function for backward compatibility
        function showHotelRooms(hotelId, hotelName) {
            if (propertiesManager) {
                propertiesManager.showHotelRooms(hotelId, hotelName);
            }
        }
    </script>
}