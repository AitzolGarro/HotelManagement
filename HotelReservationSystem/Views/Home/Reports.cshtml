@{
    ViewData["Title"] = L["Nav_Reports"].Value;
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2>@L["Reports_Title"]</h2>
                <button type="button" class="btn btn-primary" id="exportReportBtn">
                    <i class="fas fa-download"></i> @L["Reports_ExportReport"]
                </button>
            </div>
        </div>
    </div>

    <!-- Report Filters -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">@L["Reports_Filters"]</h5>
                </div>
                <div class="card-body">
                    <form id="reportFiltersForm">
                        <div class="row">
                            <div class="col-md-3">
                                <label for="reportType" class="form-label">@L["Reports_Type"]</label>
                                <select class="form-select" id="reportType" name="reportType">
                                    <option value="occupancy">@L["Reports_Occupancy"]</option>
                                    <option value="revenue">@L["Reports_Revenue"]</option>
                                    <option value="guestPattern">@L["Reports_GuestPattern"]</option>
                                </select>
                            </div>
                            <div class="col-md-2">
                                <label for="hotelFilter" class="form-label">@L["Calendar_Hotel"]</label>
                                <select class="form-select" id="hotelFilter" name="hotelId">
                                    <option value="">@L["Calendar_AllHotels"]</option>
                                </select>
                            </div>
                            <div class="col-md-2">
                                <label for="startDate" class="form-label">@L["Common_StartDate"]</label>
                                <input type="date" class="form-control" id="startDate" name="startDate" required>
                            </div>
                            <div class="col-md-2">
                                <label for="endDate" class="form-label">@L["Common_EndDate"]</label>
                                <input type="date" class="form-control" id="endDate" name="endDate" required>
                            </div>
                            <div class="col-md-2">
                                <label for="quickDateRange" class="form-label">@L["Reports_QuickRange"]</label>
                                <select class="form-select" id="quickDateRange">
                                    <option value="">@L["Reports_Custom"]</option>
                                    <option value="7">@L["Reports_Last7Days"]</option>
                                    <option value="30">@L["Reports_Last30Days"]</option>
                                    <option value="90">@L["Reports_Last90Days"]</option>
                                    <option value="365">@L["Reports_LastYear"]</option>
                                </select>
                            </div>
                            <div class="col-md-1 d-flex align-items-end">
                                <button type="submit" class="btn btn-success w-100">
                                    <i class="fas fa-chart-bar"></i> @L["Reports_Generate"]
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Report Content -->
    <div class="row">
        <div class="col-12">
            <div id="reportContent">
                <!-- Report content will be loaded here -->
                <div class="text-center py-5">
                    <i class="fas fa-chart-line fa-3x text-muted mb-3"></i>
                    <h4 class="text-muted">@L["Reports_SelectParams"]</h4>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Export Modal -->
<div class="modal fade" id="exportModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">@L["Reports_ExportReport"]</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="exportForm">
                    <div class="mb-3">
                        <label for="exportFormat" class="form-label">@L["Reports_ExportFormat"]</label>
                        <select class="form-select" id="exportFormat" name="exportFormat" required>
                            <option value="json">JSON</option>
                            <option value="pdf">PDF</option>
                            <option value="excel">Excel</option>
                            <option value="csv">CSV</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <small class="text-muted">
                            @L["Reports_ExportCurrentFilters"]
                        </small>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@L["Common_Cancel"]</button>
                <button type="button" class="btn btn-primary" id="confirmExportBtn">
                    <i class="fas fa-download"></i> @L["Common_Export"]
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/modules/reports.js"></script>
}
