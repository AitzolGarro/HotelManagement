@{
    ViewData["Title"] = "User Management";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">
        <i class="bi bi-people me-2"></i>User Management
    </h1>
    <button class="btn btn-primary" id="addUserBtn">
        <i class="bi bi-plus-circle me-1"></i>Add User
    </button>
</div>

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover" id="usersTable">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th>Accessible Hotels</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">
                            <div class="spinner-border spinner-border-sm me-2" role="status"></div>
                            Loading users...
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script>
(() => {
    const api = new ApiClient();
    const state = { users: [], hotels: [] };

    const roleName = role => ({1:'Staff',2:'Manager',3:'Admin'})[role] || role;

    async function init() {
        document.getElementById('addUserBtn')?.addEventListener('click', showAddUserModal);
        await Promise.all([loadHotels(), loadUsers()]);
    }

    async function loadHotels() {
        try { state.hotels = await api.getHotels() || []; } catch { state.hotels = []; }
    }

    async function loadUsers() {
        const tbody = document.querySelector('#usersTable tbody');
        try {
            state.users = await api.get('/auth/users') || [];
            if (!state.users.length) {
                tbody.innerHTML = `<tr><td colspan="6" class="text-center text-muted py-4">No users found</td></tr>`;
                return;
            }
            tbody.innerHTML = state.users.map(u => {
                const hotelCount = Array.isArray(u.accessibleHotelIds) ? u.accessibleHotelIds.length : 0;
                return `<tr>
                    <td>${u.firstName} ${u.lastName}</td>
                    <td>${u.email}</td>
                    <td><span class="badge bg-primary">${roleName(u.role)}</span></td>
                    <td><span class="badge ${u.isActive ? 'bg-success':'bg-secondary'}">${u.isActive ? 'Active' : 'Inactive'}</span></td>
                    <td>${hotelCount}</td>
                    <td>
                        <button class="btn btn-sm btn-outline-danger" onclick="window.deactivateUser(${u.id})" ${u.isActive ? '' : 'disabled'}>
                            <i class="bi bi-person-x"></i>
                        </button>
                    </td>
                </tr>`;
            }).join('');
        } catch (e) {
            console.error(e);
            tbody.innerHTML = `<tr><td colspan="6" class="text-center text-danger py-4">Failed to load users</td></tr>`;
        }
    }

    function showAddUserModal() {
        const hotelsOptions = state.hotels.map(h => `<option value="${h.id}">${h.name}</option>`).join('');
        const existing = document.getElementById('userModal');
        if (existing) existing.remove();
        document.body.insertAdjacentHTML('beforeend', `
            <div class="modal fade" id="userModal" tabindex="-1">
              <div class="modal-dialog modal-lg">
                <div class="modal-content">
                  <div class="modal-header">
                    <h5 class="modal-title">Add User</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                  </div>
                  <form id="userForm">
                    <div class="modal-body">
                      <div class="row g-3">
                        <div class="col-12"><div class="alert alert-info py-2 mb-0 small">Password must be at least 8 characters and include uppercase, lowercase, number, and symbol.</div></div>
                        <div class="col-md-6"><label class="form-label">First name</label><input class="form-control" name="firstName" required></div>
                        <div class="col-md-6"><label class="form-label">Last name</label><input class="form-control" name="lastName" required></div>
                        <div class="col-md-6"><label class="form-label">Email</label><input type="email" class="form-control" name="email" required></div>
                        <div class="col-md-6"><label class="form-label">Password</label><input type="password" minlength="8" class="form-control" name="password" required></div>
                        <div class="col-md-6"><label class="form-label">Role</label>
                            <select class="form-select" name="role" required>
                              <option value="1">Staff</option><option value="2">Manager</option><option value="3">Admin</option>
                            </select>
                        </div>
                        <div class="col-md-6"><label class="form-label">Accessible hotels</label>
                            <select class="form-select" name="hotelIds" multiple size="6">${hotelsOptions}</select>
                        </div>
                        <div class="col-12"><div class="text-danger small" id="userFormError"></div></div>
                      </div>
                    </div>
                    <div class="modal-footer">
                      <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                      <button type="submit" class="btn btn-primary">Create user</button>
                    </div>
                  </form>
                </div>
              </div>
            </div>`);
        const modalEl = document.getElementById('userModal');
        const modal = new bootstrap.Modal(modalEl);
        modal.show();
        modalEl.addEventListener('hidden.bs.modal', () => modalEl.remove());
        document.getElementById('userForm').addEventListener('submit', async e => {
            e.preventDefault();
            const form = new FormData(e.target);
            const hotelIds = Array.from(e.target.querySelector('[name="hotelIds"]').selectedOptions).map(o => parseInt(o.value, 10));
            const payload = {
                firstName: form.get('firstName'),
                lastName: form.get('lastName'),
                email: form.get('email'),
                password: form.get('password'),
                role: parseInt(form.get('role'), 10),
                hotelIds
            };
            try {
                await api.post('/auth/users', payload);
                modal.hide();
                UI.showSuccess('User created successfully');
                await loadUsers();
            } catch (err) {
                document.getElementById('userFormError').textContent = err.message || 'Failed to create user';
                UI.showError(err.message || 'Failed to create user');
            }
        });
    }

    window.deactivateUser = async function(id) {
        if (!confirm('Deactivate this user?')) return;
        try {
            await api.delete(`/auth/users/${id}`);
            UI.showSuccess('User deactivated successfully');
            await loadUsers();
        } catch (err) {
            UI.showError(err.message || 'Failed to deactivate user');
        }
    };

    document.addEventListener('DOMContentLoaded', init);
})();
</script>
}
