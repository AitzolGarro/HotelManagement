
@{
    ViewData["Title"] = L["Nav_Calendar"].Value;
}

<!-- ── Page Header ──────────────────────────────────────────── -->
<div class="calendar-page-header">
    <h1 class="h3 mb-0">
        <i class="bi bi-calendar3 me-2" aria-hidden="true"></i>@L["Calendar_Title"]
    </h1>

    <!-- 9.3 Quick date navigation -->
    <div class="calendar-quick-nav" role="group" aria-label="@L["Calendar_QuickNav"]">
        <button type="button" class="btn btn-outline-secondary btn-sm" id="navPrevWeek" title="@L["Calendar_PreviousWeek"]">
            <i class="bi bi-chevron-double-left" aria-hidden="true"></i>
        </button>
        <button type="button" class="btn btn-outline-primary btn-sm" id="navToday" title="@L["Calendar_GoToToday"]">
            <i class="bi bi-calendar-check me-1" aria-hidden="true"></i>@L["Calendar_Today"]
        </button>
        <button type="button" class="btn btn-outline-secondary btn-sm" id="navNextWeek" title="@L["Calendar_NextWeek"]">
            <i class="bi bi-chevron-right me-1" aria-hidden="true"></i>@L["Calendar_NextWeek"]
        </button>
        <button type="button" class="btn btn-outline-secondary btn-sm" id="navNextMonth" title="@L["Calendar_NextMonth"]">
            <i class="bi bi-chevron-double-right me-1" aria-hidden="true"></i>@L["Calendar_NextMonth"]
        </button>
        <button type="button" class="btn btn-success btn-sm ms-2" id="addReservationBtn">
            <i class="bi bi-plus-circle me-1" aria-hidden="true"></i>@L["Calendar_NewReservation"]
        </button>
    </div>
</div>

<!-- ── Filter Bar ────────────────────────────────────────────── -->
<div class="calendar-filter-bar" role="search" aria-label="@L["Calendar_Title"]">
    <div class="row g-2 align-items-end">
        <div class="col-lg-2 col-md-4 col-sm-6">
            <label for="hotelFilter" class="form-label">@L["Calendar_Hotel"]</label>
            <select class="form-select form-select-sm" id="hotelFilter" aria-label="@L["Calendar_Hotel"]">
                <option value="">@L["Calendar_AllHotels"]</option>
            </select>
        </div>
        <div class="col-lg-2 col-md-4 col-sm-6">
            <label for="roomTypeFilter" class="form-label">@L["Calendar_RoomType"]</label>
            <select class="form-select form-select-sm" id="roomTypeFilter" aria-label="@L["Calendar_RoomType"]">
                <option value="">@L["Calendar_AllTypes"]</option>
                <option value="single">@L["Calendar_RoomType_Single"]</option>
                <option value="double">@L["Calendar_RoomType_Double"]</option>
                <option value="twin">@L["Calendar_RoomType_Twin"]</option>
                <option value="triple">@L["Calendar_RoomType_Triple"]</option>
                <option value="quad">@L["Calendar_RoomType_Quad"]</option>
                <option value="suite">@L["Calendar_RoomType_Suite"]</option>
                <option value="family">@L["Calendar_RoomType_Family"]</option>
                <option value="deluxe">@L["Calendar_RoomType_Deluxe"]</option>
                <option value="standard">@L["Calendar_RoomType_Standard"]</option>
            </select>
        </div>
        <div class="col-lg-2 col-md-4 col-sm-6">
            <label for="statusFilter" class="form-label">@L["Calendar_Status"]</label>
            <select class="form-select form-select-sm" id="statusFilter" aria-label="@L["Calendar_Status"]">
                <option value="">@L["Calendar_AllStatuses"]</option>
                <option value="pending">@L["Calendar_Pending"]</option>
                <option value="confirmed">@L["Calendar_Confirmed"]</option>
                <option value="checkedin">@L["Calendar_CheckedIn"]</option>
                <option value="checkedout">@L["Calendar_CheckedOut"]</option>
                <option value="cancelled">@L["Calendar_Cancelled"]</option>
                <option value="noshow">@L["Calendar_NoShow"]</option>
            </select>
        </div>
        <div class="col-lg-3 col-md-6 col-sm-6">
            <label for="dateRangePicker" class="form-label">@L["Calendar_DateRange"]</label>
            <input type="text" class="form-control form-control-sm" id="dateRangePicker"
                   placeholder="@L["Calendar_SelectDateRange"]" readonly aria-label="@L["Calendar_DateRange"]">
        </div>
        <div class="col-lg-3 col-md-6 col-sm-12">
            <div class="d-flex gap-2 flex-wrap">
                <button type="button" class="btn btn-primary btn-sm" id="applyFilters">
                    <i class="bi bi-funnel me-1" aria-hidden="true"></i>@L["Calendar_Apply"]
                </button>
                <button type="button" class="btn btn-outline-secondary btn-sm" id="clearFilters">
                    <i class="bi bi-x-circle me-1" aria-hidden="true"></i>@L["Calendar_Clear"]
                </button>
            </div>
        </div>
    </div>

    <!-- Status Legend -->
    <ul class="cal-legend mt-2 list-unstyled" role="list" aria-label="@L["Calendar_Status"]">
        <li class="cal-legend-item"><span class="cal-legend-dot" style="background:#198754" aria-hidden="true"></span>@L["Calendar_Confirmed"]</li>
        <li class="cal-legend-item"><span class="cal-legend-dot" style="background:#ffc107" aria-hidden="true"></span>@L["Calendar_Pending"]</li>
        <li class="cal-legend-item"><span class="cal-legend-dot" style="background:#0dcaf0" aria-hidden="true"></span>@L["Calendar_CheckedIn"]</li>
        <li class="cal-legend-item"><span class="cal-legend-dot" style="background:#6c757d" aria-hidden="true"></span>@L["Calendar_CheckedOut"]</li>
        <li class="cal-legend-item"><span class="cal-legend-dot" style="background:#dc3545" aria-hidden="true"></span>@L["Calendar_Cancelled"]</li>
        <li class="cal-legend-item"><span class="cal-legend-dot" style="background:#6f42c1" aria-hidden="true"></span>@L["Calendar_NoShow"]</li>
    </ul>
</div>

<!-- ── Calendar ──────────────────────────────────────────────── -->
<div id="cal-status" class="visually-hidden" aria-live="polite" aria-atomic="true"></div>
<div class="calendar-wrapper calendar-swipe-container">
    <div id="calendar" role="application" aria-label="@L["Calendar_Title"]"></div>
</div>

<!-- ── Reservation Detail Modal ─────────────────────────────── -->
<div class="modal fade" id="reservationModal" tabindex="-1"
     aria-labelledby="reservationModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="reservationModalLabel">
                    <i class="bi bi-journal-bookmark me-1" aria-hidden="true"></i>@L["Calendar_ReservationDetails"]
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="@L["Calendar_Close"]"></button>
            </div>
            <div class="modal-body">
                <div id="reservationDetails"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@L["Calendar_Close"]</button>
                <button type="button" class="btn btn-danger" id="cancelReservationBtn" style="display:none">
                    <i class="bi bi-x-circle me-1" aria-hidden="true"></i>@L["Calendar_CancelReservation"]
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ── Add Reservation Modal ─────────────────────────────────── -->
<div class="modal fade" id="addReservationModal" tabindex="-1"
     aria-labelledby="addReservationModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addReservationModalLabel">
                    <i class="bi bi-plus-circle me-1" aria-hidden="true"></i>@L["Calendar_NewReservation"]
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="@L["Calendar_Close"]"></button>
            </div>
            <div class="modal-body">
                <form id="reservationForm" novalidate>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="guestFirstName" class="form-label">@L["Calendar_FirstName"] <span class="text-danger" aria-hidden="true">*</span></label>
                            <input type="text" class="form-control" id="guestFirstName" required autocomplete="given-name"
                                   aria-describedby="guestFirstName-error" aria-required="true">
                            <span id="guestFirstName-error" class="invalid-feedback" role="alert"></span>
                        </div>
                        <div class="col-md-6">
                            <label for="guestLastName" class="form-label">@L["Calendar_LastName"] <span class="text-danger" aria-hidden="true">*</span></label>
                            <input type="text" class="form-control" id="guestLastName" required autocomplete="family-name"
                                   aria-describedby="guestLastName-error" aria-required="true">
                            <span id="guestLastName-error" class="invalid-feedback" role="alert"></span>
                        </div>
                        <div class="col-md-6">
                            <label for="guestEmail" class="form-label">@L["Calendar_Email"]</label>
                            <input type="email" class="form-control" id="guestEmail" autocomplete="email">
                        </div>
                        <div class="col-md-6">
                            <label for="guestPhone" class="form-label">@L["Calendar_Phone"]</label>
                            <input type="tel" class="form-control" id="guestPhone" autocomplete="tel">
                        </div>
                        <div class="col-md-6">
                            <label for="reservationHotel" class="form-label">@L["Calendar_Hotel"] <span class="text-danger" aria-hidden="true">*</span></label>
                            <select class="form-select" id="reservationHotel" required
                                    aria-describedby="reservationHotel-error" aria-required="true">
                                <option value="">@L["Calendar_SelectHotel"]</option>
                            </select>
                            <span id="reservationHotel-error" class="invalid-feedback" role="alert"></span>
                        </div>
                        <div class="col-md-6">
                            <label for="reservationRoom" class="form-label">@L["Calendar_Room"] <span class="text-danger" aria-hidden="true">*</span></label>
                            <select class="form-select" id="reservationRoom" required
                                    aria-describedby="reservationRoom-error" aria-required="true">
                                <option value="">@L["Calendar_SelectRoom"]</option>
                            </select>
                            <span id="reservationRoom-error" class="invalid-feedback" role="alert"></span>
                        </div>
                        <div class="col-md-6">
                            <label for="checkInDate" class="form-label">@L["Calendar_CheckIn"] <span class="text-danger" aria-hidden="true">*</span></label>
                            <input type="date" class="form-control" id="checkInDate" required
                                   aria-describedby="checkInDate-error" aria-required="true">
                            <span id="checkInDate-error" class="invalid-feedback" role="alert"></span>
                        </div>
                        <div class="col-md-6">
                            <label for="checkOutDate" class="form-label">@L["Calendar_CheckOut"] <span class="text-danger" aria-hidden="true">*</span></label>
                            <input type="date" class="form-control" id="checkOutDate" required
                                   aria-describedby="checkOutDate-error" aria-required="true">
                            <span id="checkOutDate-error" class="invalid-feedback" role="alert"></span>
                        </div>
                        <div class="col-md-6">
                            <label for="numberOfGuests" class="form-label">@L["Calendar_Guests"] <span class="text-danger" aria-hidden="true">*</span></label>
                            <input type="number" class="form-control" id="numberOfGuests" min="1" max="20" value="1" required
                                   aria-describedby="numberOfGuests-error" aria-required="true">
                            <span id="numberOfGuests-error" class="invalid-feedback" role="alert"></span>
                        </div>
                        <div class="col-md-6">
                            <label for="totalAmount" class="form-label">@L["Calendar_TotalAmount"] <span class="text-danger" aria-hidden="true">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text" aria-hidden="true">$</span>
                                <input type="number" class="form-control" id="totalAmount" min="0.01" step="0.01" required
                                       aria-describedby="totalAmount-error" aria-required="true" aria-label="Total amount in dollars">
                            </div>
                            <span id="totalAmount-error" class="invalid-feedback" role="alert"></span>
                        </div>
                        <div class="col-12">
                            <label for="specialRequests" class="form-label">@L["Calendar_SpecialRequests"]</label>
                            <textarea class="form-control" id="specialRequests" rows="2"
                                      placeholder="@L["Calendar_SpecialRequestsPlaceholder"]"></textarea>
                        </div>
                        <div class="col-12">
                            <label for="internalNotes" class="form-label">@L["Calendar_InternalNotes"]</label>
                            <textarea class="form-control" id="internalNotes" rows="2"
                                      placeholder="@L["Calendar_InternalNotesPlaceholder"]"></textarea>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@L["Calendar_Cancel"]</button>
                <button type="button" class="btn btn-primary" id="saveReservationBtn">
                    <i class="bi bi-check-circle me-1" aria-hidden="true"></i>@L["Calendar_Save"]
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ── Drag-and-Drop Confirmation Modal ──────────────────────── -->
<div class="modal fade" id="calDragConfirmModal" tabindex="-1"
     aria-labelledby="calDragConfirmLabel" aria-hidden="true"
     data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="calDragConfirmLabel">
                    <i class="bi bi-arrows-move me-1" aria-hidden="true"></i>@L["Calendar_ConfirmDateChange"]
                </h5>
                <button type="button" class="btn-close" id="calDragCancelBtn" aria-label="@L["Calendar_Cancel"]"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted mb-3">@L["Calendar_ReviewChanges"]</p>
                <div id="calDragSummary"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" id="calDragCancelBtn2"
                        onclick="document.getElementById('calDragCancelBtn').click()">
                    <i class="bi bi-x me-1" aria-hidden="true"></i>@L["Calendar_Cancel"]
                </button>
                <button type="button" class="btn btn-primary" id="calDragConfirmBtn">
                    <i class="bi bi-check-circle me-1" aria-hidden="true"></i>@L["Calendar_ConfirmChange"]
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- FullCalendar v6 with resource-timeline plugin -->
    <link href="https://cdn.jsdelivr.net/npm/fullcalendar-scheduler@6.1.10/main.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar-scheduler@6.1.10/index.global.min.js"></script>

    <!-- Calendar-specific CSS -->
    <link rel="stylesheet" href="~/css/calendar.css" asp-append-version="true">

    <!-- Calendar JS module -->
    <script src="~/js/modules/calendar.js" asp-append-version="true"></script>

    <script>
        let calendarManager;

        document.addEventListener('DOMContentLoaded', async function () {
            if (typeof loadI18n === 'function') {
                await loadI18n();
            }
            calendarManager = new CalendarManager();
            await calendarManager.initialize();

            // ── Task 10.2: Wire FAB to "New Reservation" on mobile ──
            const fab = document.getElementById('mobileFab');
            if (fab) {
                // Show FAB on mobile
                if (window.innerWidth < 992) {
                    fab.style.removeProperty('display');
                }
                fab.addEventListener('click', () => {
                    if (calendarManager) calendarManager._showAddReservationModal();
                });
                window.addEventListener('resize', () => {
                    if (window.innerWidth < 992) {
                        fab.style.removeProperty('display');
                    } else {
                        fab.style.setProperty('display', 'none', 'important');
                    }
                });
            }

            // ── Task 10.4: Switch to mobile-friendly view on small screens ──
            _applyMobileCalendarView();
            window.addEventListener('resize', _debounce(_applyMobileCalendarView, 300));
        });

        window.addEventListener('beforeunload', async function () {
            if (calendarManager) await calendarManager.cleanup();
        });

        // ── Task 14.3: Calendar keyboard shortcuts ──
        document.addEventListener('keydown', function (e) {
            if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA' || e.target.tagName === 'SELECT') return;
            if (e.key === 't' || e.key === 'T') {
                if (calendarManager?.calendar) calendarManager.calendar.today();
            }
            if (e.key === 'ArrowLeft' && !e.altKey) {
                if (calendarManager?.calendar) calendarManager.calendar.prev();
            }
            if (e.key === 'ArrowRight' && !e.altKey) {
                if (calendarManager?.calendar) calendarManager.calendar.next();
            }
        });

        function _applyMobileCalendarView() {
            if (!calendarManager?.calendar) return;
            const w = window.innerWidth;
            const hasTimeline = typeof FullCalendar !== 'undefined' &&
                typeof FullCalendar.ResourceTimelineView !== 'undefined';
            const currentView = calendarManager.calendar.view.type;

            if (w < 576) {
                // Extra small: list view is most readable
                if (currentView !== 'listWeek') {
                    calendarManager.calendar.changeView('listWeek');
                }
            } else if (w < 768) {
                // Small: day timeline or list
                if (hasTimeline && currentView !== 'resourceTimelineDay' && currentView !== 'listWeek') {
                    calendarManager.calendar.changeView('resourceTimelineDay');
                } else if (!hasTimeline && currentView !== 'listWeek') {
                    calendarManager.calendar.changeView('listWeek');
                }
            }
            // >= 768: keep whatever view the user chose
        }

        function _debounce(fn, delay) {
            let t;
            return (...args) => { clearTimeout(t); t = setTimeout(() => fn(...args), delay); };
        }
    </script>

    @if (System.Threading.Thread.CurrentThread.CurrentUICulture.Name.StartsWith("es"))
    {
        <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/locales/es.js"></script>
    }
}
